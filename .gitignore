.env
deloitte.xlsx

# Local Python/runtime artifacts
__pycache__/
*.py[cod]

# Temporary investigation artifacts stay local.
OTTO/archive/

# Raw browser/network captures can contain cookies and session headers.
*.har
*curl*.txt
OTTO/references/xhr/
OTTO/references/**/*.png
OTTO/references/har/har_endpoint_summary.json
OTTO/references/har/local_har_summary.json
OTTO/references/har/document_body_extract_summary.json
OTTO/references/har/extracted_document_bodies/*429*.html
OTTO/references/har/sample_philips/detail_philips*.html
OTTO/references/har/sample_philips/detail_philips*_summary.json

# OTTO detail ZenRows structure probes
OTTO/references/har/detail_zenrows*_structure_*/

# Large listing HAR/page captures
OTTO/references/har/listing_pages_*.zip

# Opt-in raw-HTML audit dumps (OTTO_SAVE_HTML) are local-only
OTTO/**/raw_html/
# Amazon crawler runtime outputs
AMZN/references/
AMZN/**/data/output/
AMZN/erd.xlsx
AMZN/logs/
